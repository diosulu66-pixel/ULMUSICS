# ─────────────────────────────────────────────
# Discord Music Bot v2 — Variables de entorno
# ─────────────────────────────────────────────

# Token del bot de Discord (OBLIGATORIO)
# Obtén uno en: https://discord.com/developers/applications
DISCORD_TOKEN=tu_token_aqui

# ── Spotify API (OBLIGATORIO para búsqueda) ──
# 1. Ve a https://developer.spotify.com/dashboard
# 2. Create App → cualquier nombre/descripción
# 3. Redirect URI: http://localhost (no importa, no se usa)
# 4. Copia Client ID y Client Secret aquí:
SPOTIFY_CLIENT_ID=tu_client_id_aqui
SPOTIFY_CLIENT_SECRET=tu_client_secret_aqui

# ── Grabaciones ──────────────────────────────
# Directorio donde se guardan los MP3 grabados
# En Railway: configura un Volume y pon su path aquí
# Ejemplo Railway Volume: /data/recordings
# Por defecto (sin Volume): /mnt/recordings
RECORDINGS_DIR=./recordings

# ─────────────────────────────────────────────
# En Railway, configura estas variables en:
# Settings > Variables > Add Variable
# DISCORD_TOKEN, SPOTIFY_CLIENT_ID, SPOTIFY_CLIENT_SECRET
# ─────────────────────────────────────────────
